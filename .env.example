# ─────────────────────────────────────────────────────────────────────────────
# InfoShield AI — Social Media Posting Credentials
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this to .env.local for local dev, OR add these in:
#   Netlify Dashboard → Your Site → Site Configuration → Environment Variables
#
# IMPORTANT: Never commit real keys to Git. .env.local is gitignored.
#
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET EACH KEY:
# ─────────────────────────────────────────────────────────────────────────────
#
# ── TWITTER / X ──────────────────────────────────────────────────────────────
# 1. Go to https://developer.twitter.com/en/portal/projects-and-apps
# 2. Create a new App (or use existing)
# 3. Enable "Read and Write" permissions in App Settings → User authentication settings
# 4. Go to App → Keys and Tokens
# 5. Copy API Key/Secret  (Consumer Keys section)
# 6. Click "Generate" under Access Token and Secret (User Access Token section)
#    IMPORTANT: The account that generated the tokens = the account that posts!
#
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# ── FACEBOOK ─────────────────────────────────────────────────────────────────
# 1. Go to https://developers.facebook.com → Create App → Business type
# 2. Add "Facebook Login" and "Pages API" products
# 3. Go to https://developers.facebook.com/tools/explorer/
# 4. Select your App, click "Get User Access Token"
# 5. Grant: pages_manage_posts, pages_read_engagement permissions
# 6. Click the "i" next to your page → copy the Page ID
# 7. Run this in Graph API Explorer to get a LONG-LIVED page token:
#    GET /me/accounts  → copy the "access_token" for your page
#    (Long-lived tokens last 60 days; you'll need to refresh periodically)
# IMPORTANT: Posts from the Page, not your personal profile
#
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_PAGE_TOKEN=your_facebook_page_access_token_here

# ── LINKEDIN ─────────────────────────────────────────────────────────────────
# 1. Go to https://www.linkedin.com/developers/apps → Create App
# 2. Under Products, request "Share on LinkedIn"
# 3. Go to Auth tab, add OAuth 2.0 scope: w_member_social
# 4. Use OAuth 2.0 Authorization Code Flow to get an access token:
#    Authorize URL: https://www.linkedin.com/oauth/v2/authorization
#    Scopes: r_liteprofile, w_member_social
# 5. After authorizing, exchange code for access token
#    POST https://www.linkedin.com/oauth/v2/accessToken
# 6. Get your Person URN:
#    GET https://api.linkedin.com/v2/me  → copy the "id" field
#    URN format: urn:li:person:{id}
# IMPORTANT: Access tokens last 60 days; rotating required after expiry
#
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_LINKEDIN_ID_HERE
